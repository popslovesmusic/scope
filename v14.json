        "path": "v14/sim_v14_stage1.py",
        "purpose": "Main v14 stage-1 runner for signature-native demo and reporting."
      },
      {
        "path": "v14/chat_v14_session.py",
        "purpose": "Optional later surface for chat-style testing after binary demo is stable."
      }
    ],
    "script_files": [
      {
