      },
      {
        "path": "v14/tests/test_orientation_symmetry.py",
        "purpose": "Validate symmetry handling and operator distinctness."
      },
      {
        "path": "v14/tests/test_binary_demo.py",
        "purpose": "Smoke-test binary task behavior."
      }
    ],
    "doc_files": [
      {
        "path": "v14/V14_SPEC.md",
        "purpose": "Human-readable version of the spec."
      },
      {
        "path": "v14/README.md",
        "purpose": "Usage, layout, and run instructions."
      }
    ]
  },
  "minimum_build_order": [
    "create config_v14_scaffold.json",
    "build signature_state.py",
    "build peak_detector.py",
    "build corridor_gate.py",
    "build orientation_ops.py",
    "build reasoning_loop.py",
    "build readout_heads.py",
    "build sim_v14_stage1.py",
    "build run_v14_binary_demo.py",
    "add tests"
  ],
  "explicit_non_goals_for_first_pass": [
    "full chat replacement",
    "large task suite",
    "full agentization",
    "complex corridor memory reuse across long sessions",
    "large-scale token generation"
  ],
  "one_line_charter": "v14 redefines the system around a native spectral-signature state where corridor, token family, and orientation operator are intrinsic computational objects rather than overlays on a token pipeline."
}