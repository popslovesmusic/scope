      },
      {
        "path": "v14/scripts/run_v14_phase_trace.py",
        "purpose": "Render or dump per-phase traces for debugging and interpretation."
      },
      {
        "path": "v14/scripts/compare_v14_runs.py",
        "purpose": "Compare v14 runs across configs and tasks."
      }
    ],
    "test_files": [
